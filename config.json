{
  "dataset_name": "CLV_Synthetic_Data",
  "seed": 42,
  "output_format": "csv",
  
  "customers": {
    "min": 100,
    "max": 500,
    "segments": {
      "premium": {
        "share": 0.15,
        "avg_check": 5000,
        "check_std": 2000,
        "frequency_weeks": 0.5,
        "churn_rate": 0.05,
        "lifetime_months": 24
      },
      "regular": {
        "share": 0.55,
        "avg_check": 1500,
        "check_std": 600,
        "frequency_weeks": 1.5,
        "churn_rate": 0.15,
        "lifetime_months": 12
      },
      "occasional": {
        "share": 0.30,
        "avg_check": 500,
        "check_std": 300,
        "frequency_weeks": 4,
        "churn_rate": 0.35,
        "lifetime_months": 6
      }
    }
  },
  
  "transactions": {
    "date_range": {
      "start": "2022-01-01",
      "end": "2024-12-31"
    },
    "seasonality": {
      "december_multiplier": 2.5,
      "black_friday_multiplier": 3.0,
      "summer_slowdown": 0.7
    },
    "promotions": {
      "enabled": true,
      "discount_probability": 0.3,
      "avg_discount": 0.15
    },
    "noise": {
      "enabled": true,
      "amount_noise": 0.1,
      "skip_probability": 0.05
    }
  },
  
  "clv_formula": "simple",
  "export_metadata": true
}